# ---- Database (Vercel Postgres / Neon) ----
# In Vercel: Storage > Create > Postgres, then copy the connection string here.
# Locally you can use a free Neon database (https://neon.tech).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ---- Auth.js (NextAuth) ----
# Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# ---- Vercel Blob (test evidence file storage) ----
# In Vercel: Storage > Create > Blob, then copy the read/write token here.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ---- Jira (link-only; no API calls) ----
# Used to turn a Jira key like PROJ-123 into a clickable link.
# NEXT_PUBLIC_ copy lets the browser render Jira links in client components.
JIRA_BASE_URL="https://your-company.atlassian.net"
NEXT_PUBLIC_JIRA_BASE_URL="https://your-company.atlassian.net"
