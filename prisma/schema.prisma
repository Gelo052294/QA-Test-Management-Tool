// Prisma schema for the QA Test Management Tool.
// Storage: Postgres (Vercel Postgres / Neon).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  tester
}

enum TestCasePriority {
  low
  medium
  high
  critical
}

enum TestCaseStatus {
  draft
  active
  deprecated
}

enum CycleStatus {
  active
  completed
}

enum ExecutionStatus {
  not_run
  pass
  fail
  blocked
}

enum FolderKind {
  testcase
  cycle
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(tester)
  apiToken     String?  @unique // Bearer token for programmatic API access
  createdAt    DateTime @default(now())

  createdProjects   Project[]       @relation("ProjectCreatedBy")
  createdTestCases  TestCase[]      @relation("TestCaseCreatedBy")
  createdCycles     TestCycle[]     @relation("CycleCreatedBy")
  executions        TestExecution[] @relation("ExecutionExecutedBy")
  uploadedEvidence  Evidence[]        @relation("EvidenceUploadedBy")
  cycleChanges      CycleHistory[]    @relation("CycleHistoryChangedBy")
  testCaseChanges   TestCaseHistory[] @relation("TestCaseHistoryChangedBy")
}

model Project {
  id          String   @id @default(cuid())
  key         String   @unique // short uppercase code, e.g. AUR
  name        String
  description String?
  tcCounter   Int      @default(0) // per-project test case number
  cyCounter   Int      @default(0) // per-project cycle number
  createdById String
  createdBy   User     @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  testCases TestCase[]
  cycles    TestCycle[]
  folders   Folder[]
}

model Folder {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      FolderKind
  name      String
  hidden    Boolean    @default(false)
  parentId  String?
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("FolderTree")
  createdAt DateTime   @default(now())

  testCases TestCase[]
  cycles    TestCycle[]

  @@index([projectId, kind])
  @@index([parentId])
}

model TestCase {
  id            String           @id @default(cuid())
  key           String           @unique // human-friendly, e.g. AUR-T1
  seq           Int              @unique @default(autoincrement()) // global tiebreaker
  title         String
  description   String?
  preconditions String?
  steps         Json             @default("[]") // [{ step, expectedResult }]
  priority      TestCasePriority @default(medium)
  status        TestCaseStatus   @default(active)
  folder        String? // legacy free-text label (superseded by folderId)
  folderId      String?
  folderRef     Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  jiraKey       String? // e.g. PROJ-123 (link-only)
  projectId     String? // made required after data migration
  project       Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User             @relation("TestCaseCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  executions TestExecution[]
  history    TestCaseHistory[]

  @@index([projectId])
  @@index([folderId])
  @@index([jiraKey])
}

model TestCaseHistory {
  id          String   @id @default(cuid())
  testCaseId  String
  testCase    TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  changedById String
  changedBy   User     @relation("TestCaseHistoryChangedBy", fields: [changedById], references: [id])
  field       String
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  @@index([testCaseId, createdAt])
}

model TestCycle {
  id          String      @id @default(cuid())
  key         String?     // e.g. AUR-C1 (uniqueness enforced via per-project counter)
  name        String
  description String?
  status      CycleStatus @default(active)
  startDate   DateTime?
  endDate     DateTime?
  projectId   String? // made required after data migration
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folderId    String?
  folderRef   Folder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User        @relation("CycleCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())

  executions TestExecution[]
  history    CycleHistory[]

  @@index([projectId])
  @@index([folderId])
}

model CycleHistory {
  id          String    @id @default(cuid())
  cycleId     String
  cycle       TestCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  changedById String
  changedBy   User      @relation("CycleHistoryChangedBy", fields: [changedById], references: [id])
  field       String // e.g. "Name", "Folder", "Executed by (AUR-T1)", "Test cases"
  oldValue    String?
  newValue    String?
  createdAt   DateTime  @default(now())

  @@index([cycleId, createdAt])
}

model TestExecution {
  id            String          @id @default(cuid())
  cycleId       String
  cycle         TestCycle       @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  testCaseId    String
  testCase      TestCase        @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  status        ExecutionStatus @default(not_run)
  comment       String?
  defectJiraKey String?
  executedById  String?
  executedBy    User?           @relation("ExecutionExecutedBy", fields: [executedById], references: [id])
  executedAt    DateTime?
  createdAt     DateTime        @default(now())

  evidence Evidence[]

  @@unique([cycleId, testCaseId])
  @@index([executedAt])
}

model Evidence {
  id           String        @id @default(cuid())
  executionId  String
  execution    TestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  fileName     String
  url          String
  contentType  String?
  uploadedById String
  uploadedBy   User          @relation("EvidenceUploadedBy", fields: [uploadedById], references: [id])
  uploadedAt   DateTime      @default(now())
}
